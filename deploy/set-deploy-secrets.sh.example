#!/usr/bin/env bash
# Copy to set-deploy-secrets.sh and fill in values. Do not commit set-deploy-secrets.sh.
# Usage: source deploy/set-deploy-secrets.sh   (from repo root)
# Then run terraform from deploy/terraform/ or deploy/terraform-webapp/.

# Batch stack (deploy/terraform/)
export TF_VAR_hf_token=""
# export TF_VAR_yt_cookies_file_path="/path/to/cookies.txt"
# export TF_VAR_enable_cloudfront=true

# Web app stack (deploy/terraform-webapp/; apply after Batch stack exists)
# export TF_VAR_existing_s3_bucket_name="your-bucket-name"
# export TF_VAR_admin_username="admin"
# export TF_VAR_admin_password=""
# export TF_VAR_db_password=""
