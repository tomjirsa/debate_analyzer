# Dedicated LLM image for transcript analysis (GPU; Transformers with CUDA).
# Build: docker build -f Dockerfile.llm.gpu -t debate-analyzer-llm:latest-gpu .
# Push to ECR (debate-analyzer-llm repo) with tag latest-gpu, then submit Batch job
# with the GPU LLM job definition (e.g. submit-llm-analysis-job-gpu.sh).
# LLM_USE_GPU is set by the Batch job definition; do not set it here.
FROM pytorch/pytorch:2.4.1-cuda12.1-cudnn9-runtime

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# AWS CLI for S3
RUN curl -sS "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip \
    && unzip -q /tmp/awscliv2.zip -d /tmp \
    && /tmp/aws/install -b /usr/local/bin \
    && rm -rf /tmp/awscliv2.zip /tmp/aws

WORKDIR /app

# Base image has torch with CUDA; add transformers, boto3, pyarrow (loader needs pyarrow for parquet)
RUN pip install --no-cache-dir "transformers>=4.45.0" "boto3>=1.28" "pyarrow>=18.0.0"

# Copy only the code needed for LLM analysis (analysis module, batch llm job, api loader)
COPY src/debate_analyzer /app/src/debate_analyzer
ENV PYTHONPATH=/app/src

COPY deploy/scripts/entrypoints/entrypoint_llm_analysis.sh /entrypoint_llm_analysis.sh
RUN chmod +x /entrypoint_llm_analysis.sh

# Default model (override with LLM_MODEL_ID env in job)
ENV LLM_MODEL_ID=Qwen/Qwen2-1.5B-Instruct

ENTRYPOINT []
CMD ["/entrypoint_llm_analysis.sh"]
