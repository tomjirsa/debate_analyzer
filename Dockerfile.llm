# Dedicated LLM image for transcript analysis (CPU-only; Transformers).
# Build: docker build -f Dockerfile.llm -t debate-analyzer-llm:latest .
# Push to ECR (debate-analyzer-llm repo), then submit Batch job with TRANSCRIPT_S3_URI.
FROM python:3.10-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# AWS CLI for S3
RUN curl -sS "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip \
    && unzip -q /tmp/awscliv2.zip -d /tmp \
    && /tmp/aws/install -b /usr/local/bin \
    && rm -rf /tmp/awscliv2.zip /tmp/aws

WORKDIR /app

# CPU-only torch from PyTorch index; then transformers and boto3 from PyPI (--index-url would hide PyPI)
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu \
    && pip install --no-cache-dir "transformers>=4.45.0" "boto3>=1.28"

# Copy only the code needed for LLM analysis (analysis module, batch llm job, api loader)
COPY src/debate_analyzer /app/src/debate_analyzer
ENV PYTHONPATH=/app/src

COPY deploy/scripts/entrypoints/entrypoint_llm_analysis.sh /entrypoint_llm_analysis.sh
RUN chmod +x /entrypoint_llm_analysis.sh

# Default model (override with LLM_MODEL_ID env in job)
ENV LLM_MODEL_ID=Qwen/Qwen2-1.5B-Instruct

ENTRYPOINT []
CMD ["/entrypoint_llm_analysis.sh"]
